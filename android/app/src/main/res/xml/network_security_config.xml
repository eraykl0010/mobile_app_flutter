<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Varsayılan: Sadece HTTPS trafiğine izin ver -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- API sunucusu — sadece HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onlinepdks.com.tr</domain>
    </domain-config>
</network-security-config>